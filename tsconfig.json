{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    
    /* Path Aliases - Removed baseUrl and updated paths to be root-relative */
    
    "paths": {
      "@/*": ["./app/*"],
      "@assets/*": ["./assets/*"],
      "@services/*": ["./backend/services/*"],
      "@components/*": ["./components/*"]
    },

    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "bundler"
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts", 
    "expo-env.d.ts"
  ]
}