{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,

    "baseUrl": ".",

    "paths": {
      "@/*": ["app/*"],
      "@assets/*": ["assets/*"],
      "@services/*": ["backend/services/*"],
      "@components/*": ["components/*"]
    },

    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "moduleResolution": "bundler"
  },

  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.d.ts"
  ]
}